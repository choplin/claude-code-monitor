{
  "hooks": [
    {
      "event": "SessionStart",
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/claude-code-monitor hook SessionStart"
    },
    {
      "event": "SessionEnd",
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/claude-code-monitor hook SessionEnd"
    },
    {
      "event": "UserPromptSubmit",
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/claude-code-monitor hook UserPromptSubmit"
    },
    {
      "event": "PreToolUse",
      "matcher": "AskUserQuestion",
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/claude-code-monitor hook PreToolUse AskUserQuestion"
    },
    {
      "event": "PreToolUse",
      "matcher": "ExitPlanMode",
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/claude-code-monitor hook PreToolUse ExitPlanMode"
    },
    {
      "event": "Stop",
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/claude-code-monitor hook Stop"
    }
  ]
}
